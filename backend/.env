# backend/.env.production

NODE_ENV=production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/malware_detection

# Redis
REDIS_HOST=your-redis-instance.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ML Service
ML_SERVICE_URL=https://ml-service.yourdomain.com

# Security
JWT_SECRET=super_secret_production_key_change_this
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100